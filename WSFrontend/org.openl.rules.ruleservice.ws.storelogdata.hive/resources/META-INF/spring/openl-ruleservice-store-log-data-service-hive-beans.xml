<?xml version='1.0'?>
<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="hiveOperations" class="org.openl.rules.ruleservice.storelogdata.hive.HiveOperations">
        <property name="createTableEnabled" value="${ruleservice.store.logs.hive.table.create}"/>
        <property name="connectionURL" value="${hive.connection.url}"/>
    </bean>

    <!-- Hive logging store service bean. -->
    <bean id="hiveStoreLogDataService" class="org.openl.rules.ruleservice.storelogdata.hive.HiveStoreLogDataService">
        <property name="hiveOperations" ref="hiveOperations"/>
    </bean>

</beans>
