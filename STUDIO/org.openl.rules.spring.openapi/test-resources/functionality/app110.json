{
  "openapi": "3.0.1",
  "info": {
    "title": "OpenL Studio API",
    "version": "*"
  },
  "servers": [
    {
      "url": "http://localhost"
    }
  ],
  "paths": {
    "/status": {
      "get": {
        "operationId": "getStatus",
        "responses": {
          "200": {
            "description": "default response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusView"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Message": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "summary": {
            "type": "string"
          }
        }
      },
      "StatusView": {
        "type": "object",
        "properties": {
          "messages": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "INFO": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Message"
                }
              },
              "WARN": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Message"
                }
              },
              "ERROR": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          },
          "labels": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "read": {
                "type": "string"
              },
              "write": {
                "type": "string"
              }
            }
          },
          "counters": {
            "type": "object",
            "additionalProperties": {
              "type": "integer",
              "format": "int32"
            }
          }
        }
      }
    }
  }
}
