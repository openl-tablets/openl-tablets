{
  "openapi": "3.0.1",
  "info": {
    "title": "OpenL Studio API",
    "version": "*"
  },
  "servers": [
    {
      "url": "http://localhost"
    }
  ],
  "paths": {
    "/files/{folder}/{path}": {
      "post": {
        "operationId": "*",
        "parameters": [
          {
            "name": "folder",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "path",
            "description": "File path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "createFolders",
            "in": "query",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "default": {
            "description": "default response"
          }
        }
      }
    }
  },
  "components": {}
}
