<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Releases JGit's process-wide resources (background worker thread and NLS localization cache) when the context
         closes. Imported by ExtensionsConfiguration only when the git repository is deployed. -->
    <bean class="org.openl.rules.repository.git.JGitCleanup" lazy-init="false"/>
</beans>
