<project>
    <name>Example With Dependency</name>
    <comment>More complex project, shows how to structure project with dependencies</comment>
    <modules>
        <module>
            <rules-root path="rules/*.xlsx"/>
        </module>
    </modules>
    <exposed-methods>
        <include>Ping</include>
    </exposed-methods>
    <dependencies>
        <dependency>
            <name>Dependency Example</name>
            <autoIncluded>true</autoIncluded>
        </dependency>
    </dependencies>
</project>
