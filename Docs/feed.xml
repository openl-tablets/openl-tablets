---
layout: null
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
  <title>{{ site.title | xml_escape }} — Release Notes</title>
  <subtitle>{{ site.description | xml_escape }}</subtitle>
  <link href="{{ '/feed.xml' | absolute_url }}" rel="self" type="application/atom+xml"/>
  <link href="{{ '/' | absolute_url }}" rel="alternate" type="text/html"/>
  <id>{{ '/' | absolute_url }}</id>
  <author>
    <name>{{ site.author.name | xml_escape }}</name>
  </author>
  {% assign releases = site.pages
     | where_exp: "p", "p.path contains 'release-notes/'"
     | where_exp: "p", "p.name == 'index.md'"
     | where_exp: "p", "p.path != 'release-notes/index.md'"
     | sort: "date"
     | reverse %}
  {% assign latest = releases | first %}
  {% if latest %}<updated>{{ latest.date | date_to_xmlschema }}</updated>{% endif %}
  {% for rp in releases limit:20 %}
  <entry>
    <title>{{ rp.title | xml_escape }}</title>
    <link href="{{ rp.url | absolute_url }}" rel="alternate" type="text/html"/>
    <id>{{ rp.url | absolute_url }}</id>
    <published>{{ rp.date | date_to_xmlschema }}</published>
    <updated>{{ rp.date | date_to_xmlschema }}</updated>
    {% if rp.description %}<summary>{{ rp.description | xml_escape }}</summary>{% endif %}
  </entry>
  {% endfor %}
</feed>
